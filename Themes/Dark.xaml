<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackground"               Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackground"             Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SurfaceBackground"           Color="#252525"/>
    <SolidColorBrush x:Key="SubSurfaceBackground"        Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SearchBoxBackground"         Color="#3C3C3C"/>
    <SolidColorBrush x:Key="PrimaryForeground"           Color="#DCDCDC"/>
    <SolidColorBrush x:Key="SecondaryForeground"         Color="#AAAAAA"/>
    <SolidColorBrush x:Key="MutedForeground"             Color="#666666"/>
    <SolidColorBrush x:Key="AppBorderBrush"              Color="#555555"/>
    <SolidColorBrush x:Key="ColumnHeaderBorderBrush"     Color="#444444"/>
    <SolidColorBrush x:Key="SplitterBrush"               Color="#333333"/>
    <SolidColorBrush x:Key="NewProcessBackground"        Color="#1A4A1A"/>
    <SolidColorBrush x:Key="NewProcessForeground"        Color="#66FF66"/>
    <SolidColorBrush x:Key="TerminatedProcessBackground" Color="#4A1A1A"/>
    <SolidColorBrush x:Key="TerminatedProcessForeground" Color="#FF6666"/>
    <SolidColorBrush x:Key="ThemeButtonBackground"       Color="#3C3C3C"/>
    <SolidColorBrush x:Key="ThemeButtonForeground"       Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ThemeButtonActiveBg"         Color="#555555"/>
    <SolidColorBrush x:Key="ThemeButtonActiveFg"         Color="White"/>
    <SolidColorBrush x:Key="ThemeButtonBorder"           Color="#555555"/>
    <!-- Context menu colors -->
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}"          Color="#2D2D2D"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}"      Color="#DCDCDC"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#1A3A5C"/>
    <!-- Selection colors — applied to DataGrid (and any other control) via WPF's system brush lookup -->
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#1A3A5C"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#DCDCDC"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"      Color="#162D42"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"  Color="#AAAAAA"/>
</ResourceDictionary>
