<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackground"               Color="#F0F0F0"/>
    <SolidColorBrush x:Key="PanelBackground"             Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SurfaceBackground"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubSurfaceBackground"        Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SearchBoxBackground"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryForeground"           Color="#111111"/>
    <SolidColorBrush x:Key="SecondaryForeground"         Color="#555555"/>
    <SolidColorBrush x:Key="MutedForeground"             Color="#999999"/>
    <SolidColorBrush x:Key="AppBorderBrush"              Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ColumnHeaderBorderBrush"     Color="#DDDDDD"/>
    <SolidColorBrush x:Key="SplitterBrush"               Color="#CCCCCC"/>
    <SolidColorBrush x:Key="NewProcessBackground"        Color="#D4F7D4"/>
    <SolidColorBrush x:Key="NewProcessForeground"        Color="#1A6B1A"/>
    <SolidColorBrush x:Key="TerminatedProcessBackground" Color="#F7D4D4"/>
    <SolidColorBrush x:Key="TerminatedProcessForeground" Color="#8B0000"/>
    <SolidColorBrush x:Key="ThemeButtonBackground"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeButtonForeground"       Color="#555555"/>
    <SolidColorBrush x:Key="ThemeButtonActiveBg"         Color="#0078D4"/>
    <SolidColorBrush x:Key="ThemeButtonActiveFg"         Color="White"/>
    <SolidColorBrush x:Key="ThemeButtonBorder"           Color="#CCCCCC"/>
    <!-- Context menu colors -->
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}"      Color="#111111"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#0078D4"/>
    <!-- Selection colors — applied to DataGrid (and any other control) via WPF's system brush lookup -->
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#0078D4"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="White"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"      Color="#C5DFF8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"  Color="#111111"/>
</ResourceDictionary>
