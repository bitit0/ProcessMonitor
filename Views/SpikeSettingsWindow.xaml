<Window x:Class="ProcessMonitor.Views.SpikeSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spike Thresholds" Width="340" Height="250"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="20">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- CPU -->
            <CheckBox x:Name="CpuCheck" Grid.Row="0" Grid.Column="0" Content="CPU" VerticalAlignment="Center"/>
            <TextBox  x:Name="CpuValue" Grid.Row="0" Grid.Column="1" VerticalContentAlignment="Center" Margin="0,4"
                      IsEnabled="{Binding IsChecked, ElementName=CpuCheck}"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="6,0,0,0"/>

            <!-- Memory -->
            <CheckBox x:Name="MemCheck" Grid.Row="1" Grid.Column="0" Content="Memory" VerticalAlignment="Center"/>
            <TextBox  x:Name="MemValue" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center" Margin="0,4"
                      IsEnabled="{Binding IsChecked, ElementName=MemCheck}"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="6,0,0,0"/>

            <!-- Network -->
            <CheckBox x:Name="NetCheck" Grid.Row="2" Grid.Column="0" Content="Network" VerticalAlignment="Center"/>
            <TextBox  x:Name="NetValue" Grid.Row="2" Grid.Column="1" VerticalContentAlignment="Center" Margin="0,4"
                      IsEnabled="{Binding IsChecked, ElementName=NetCheck}"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="MB/s" VerticalAlignment="Center" Margin="6,0,0,0"/>

            <!-- GPU -->
            <CheckBox x:Name="GpuCheck" Grid.Row="3" Grid.Column="0" Content="GPU" VerticalAlignment="Center"/>
            <TextBox  x:Name="GpuValue" Grid.Row="3" Grid.Column="1" VerticalContentAlignment="Center" Margin="0,4"
                      IsEnabled="{Binding IsChecked, ElementName=GpuCheck}"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK"     Width="72" IsDefault="True"  Click="Ok_Click"     Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="72" IsCancel="True"   Click="Cancel_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
