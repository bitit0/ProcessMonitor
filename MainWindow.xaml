<Window x:Class="ProcessMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProcessMonitor.ViewModels"
        xmlns:views="clr-namespace:ProcessMonitor.Views"
        xmlns:conv="clr-namespace:ProcessMonitor.Converters"
        Title="Process Monitor" Height="700" Width="1100"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>

        <!-- DataGrid row -->
        <Style x:Key="ProcessRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsNew}" Value="True"/>
                        <Condition Binding="{Binding DataContext.HighlightProcesses, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource NewProcessBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource NewProcessForeground}"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsTerminated}" Value="True"/>
                        <Condition Binding="{Binding DataContext.HighlightProcesses, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource TerminatedProcessBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TerminatedProcessForeground}"/>
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsSpike}" Value="True">
                    <Setter Property="Background" Value="#50FF2020"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchMatch}" Value="False">
                    <Setter Property="Opacity" Value="0.25"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Tab control -->
        <Style TargetType="TabControl">
            <Setter Property="Background"       Value="{DynamicResource AppBackground}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab item -->
        <Style TargetType="TabItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource SecondaryForeground}"/>
            <Setter Property="Padding"         Value="18,10"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <TextBlock Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBackground}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar button -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource ThemeButtonBackground}"/>
            <Setter Property="Foreground"       Value="{DynamicResource ThemeButtonForeground}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource ThemeButtonBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,5"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeButtonActiveBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeButtonActiveFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Depth → indent width converter -->
        <conv:DepthToWidth x:Key="DepthToWidth"/>

        <!-- Expand/collapse toggle button for tree nodes -->
        <Style x:Key="ExpandButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="{DynamicResource SecondaryForeground}"/>
            <Setter Property="Content"          Value="▶"/>
            <Setter Property="Width"            Value="14"/>
            <Setter Property="Height"           Value="14"/>
            <Setter Property="FontSize"         Value="8"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="▼"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu bar -->
        <Menu Grid.Row="0"
              Background="#F0F0F0"
              Foreground="#111111"
              BorderBrush="#D0D0D0"
              BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="Export CSV" Click="ExportCsv_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Refresh Rate">
                    <MenuItem x:Name="Rate500"  Header="0.5 seconds" IsCheckable="True"                  Click="RefreshRate_Click" Tag="500"/>
                    <MenuItem x:Name="Rate1000" Header="1 second"    IsCheckable="True" IsChecked="True" Click="RefreshRate_Click" Tag="1000"/>
                    <MenuItem x:Name="Rate2000" Header="2 seconds"   IsCheckable="True"                  Click="RefreshRate_Click" Tag="2000"/>
                    <MenuItem x:Name="Rate5000" Header="5 seconds"   IsCheckable="True"                  Click="RefreshRate_Click" Tag="5000"/>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="PauseMonitoringItem"     Header="Pause Monitoring"        IsCheckable="True" Click="PauseMonitoring_Click"/>
                <MenuItem x:Name="AlwaysOnTopItem"         Header="Always on Top"           IsCheckable="True" Click="AlwaysOnTop_Click"/>
                <MenuItem x:Name="MinimizeToTrayItem"      Header="Minimize to Tray"        IsCheckable="True" Click="MinimizeToTray_Click"/>
                <Separator/>
                <MenuItem x:Name="HighlightNewTerminatedItem" Header="Highlight New/Terminated" IsCheckable="True" Click="HighlightNewTerminated_Click"/>
                <Separator/>
                <MenuItem x:Name="MonitorSpikesItem" Header="Monitor Spikes" IsCheckable="True" Click="MonitorSpikes_Click"/>
                <MenuItem Header="Spike Thresholds..." Click="SpikeSettings_Click"/>
                <Separator/>
                <MenuItem x:Name="StartupWithWindowsItem" Header="Start with Windows" IsCheckable="True" Click="StartupWithWindows_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Theme">
                    <MenuItem x:Name="ThemeSystem" Header="System" IsCheckable="True" IsChecked="True" Click="ThemeSystem_Click"/>
                    <MenuItem x:Name="ThemeLight"  Header="Light"  IsCheckable="True"                  Click="ThemeLight_Click"/>
                    <MenuItem x:Name="ThemeDark"   Header="Dark"   IsCheckable="True"                  Click="ThemeDark_Click"/>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Tab control -->
        <TabControl x:Name="MainTabControl" Grid.Row="1">

            <!-- ── Processes tab ── -->
            <TabItem Header="Processes">
                <Grid Background="{DynamicResource AppBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="180"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <Grid Grid.Row="0" Background="{DynamicResource PanelBackground}" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="8">
                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource SearchBoxBackground}"
                                     Foreground="{DynamicResource PrimaryForeground}"
                                     BorderBrush="{DynamicResource AppBorderBrush}"
                                     CaretBrush="{DynamicResource PrimaryForeground}"
                                     Padding="8,6" FontSize="13"/>
                            <TextBlock Text="Search processes..." IsHitTestVisible="False"
                                       Foreground="{DynamicResource MutedForeground}"
                                       VerticalAlignment="Center" Margin="10,0" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ProcessCount, StringFormat='{}{0} processes'}"
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12"/>
                    </Grid>

                    <!-- Process table | Detail panel -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="ProcessGrid"
                                  Grid.Column="0"
                                  ItemsSource="{Binding TreeNodesView}"
                                  SelectedItem="{Binding SelectedNode}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  Sorting="ProcessGrid_Sorting"
                                  SelectionChanged="ProcessGrid_SelectionChanged"
                                  GridLinesVisibility="None"
                                  Background="{DynamicResource SurfaceBackground}"
                                  Foreground="{DynamicResource PrimaryForeground}"
                                  RowBackground="{DynamicResource SurfaceBackground}"
                                  AlternatingRowBackground="{DynamicResource SurfaceBackground}"
                                  RowHeaderWidth="0"
                                  BorderThickness="0"
                                  RowStyle="{StaticResource ProcessRowStyle}"
                                  SelectionUnit="FullRow"
                                  FontSize="12"
                                  PreviewMouseRightButtonDown="ProcessGrid_PreviewMouseRightButtonDown"
                                  ContextMenuOpening="ProcessGrid_ContextMenuOpening">
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                             Background="{DynamicResource SurfaceBackground}"
                                             BorderBrush="{DynamicResource AppBorderBrush}"
                                             Foreground="{DynamicResource PrimaryForeground}">
                                    <MenuItem Header="End Process"      Click="EndProcess_Click"/>
                                    <MenuItem Header="End Process Tree" Click="EndProcessTree_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Open File Location" Click="OpenFileLocation_Click"
                                              IsEnabled="{Binding SelectedNode.Vm.HasFullPath, FallbackValue=False}"/>
                                    <Separator/>
                                    <MenuItem Header="Copy PID"       Click="CopyPid_Click"/>
                                    <MenuItem Header="Copy Full Path" Click="CopyFullPath_Click"
                                              IsEnabled="{Binding SelectedNode.Vm.HasFullPath, FallbackValue=False}"/>
                                    <Separator/>
                                    <MenuItem Header="Set Priority">
                                        <MenuItem Header="Low"          Tag="Idle"        Click="SetPriority_Click"/>
                                        <MenuItem Header="Below Normal" Tag="BelowNormal" Click="SetPriority_Click"/>
                                        <MenuItem Header="Normal"       Tag="Normal"      Click="SetPriority_Click"/>
                                        <MenuItem Header="Above Normal" Tag="AboveNormal" Click="SetPriority_Click"/>
                                        <MenuItem Header="High"         Tag="High"        Click="SetPriority_Click"/>
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="BorderThickness"  Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="{DynamicResource PanelBackground}"/>
                                    <Setter Property="Foreground"      Value="{DynamicResource SecondaryForeground}"/>
                                    <Setter Property="Padding"         Value="8,6"/>
                                    <Setter Property="BorderBrush"     Value="{DynamicResource ColumnHeaderBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PID"         Binding="{Binding Vm.PID}"      Width="65"  SortMemberPath="Vm.PID"/>

                                <DataGridTemplateColumn Header="Name" Width="*" SortMemberPath="Vm.Name">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0">
                                                <!-- Indent spacer based on tree depth -->
                                                <Border Width="{Binding Depth, Converter={StaticResource DepthToWidth}}" Height="1"/>
                                                <!-- Expand/collapse toggle (hidden for leaf nodes) -->
                                                <ToggleButton IsChecked="{Binding IsExpanded, Mode=OneWay}"
                                                              Click="ExpandButton_Click"
                                                              Tag="{Binding}">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton" BasedOn="{StaticResource ExpandButtonStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasChildren}" Value="False">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <TextBlock Text="{Binding Vm.Name}" VerticalAlignment="Center" Margin="3,0,0,0"
                                                           Foreground="{DynamicResource PrimaryForeground}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn x:Name="CpuColumn"  Header="CPU %"       Binding="{Binding Vm.CpuPercent, StringFormat={}{0:F1}}" Width="80"  SortMemberPath="Vm.CpuPercent"/>
                                <DataGridTextColumn x:Name="MemColumn"  Header="Memory (MB)" Binding="{Binding Vm.MemoryMB}"          Width="110" SortMemberPath="Vm.MemoryMB"/>
                                <DataGridTextColumn x:Name="DiskColumn" Header="Disk"         Binding="{Binding Vm.DiskBpsDisplay}"    Width="110" SortMemberPath="Vm.DiskReadBps"/>
                                <DataGridTextColumn x:Name="NetColumn"  Header="Network"      Binding="{x:Null}"                       Width="145"/>
                                <DataGridTextColumn Header="Threads"     Binding="{Binding Vm.ThreadCount}" Width="70"  SortMemberPath="Vm.ThreadCount"/>
                                <DataGridTextColumn Header="Status"      Binding="{Binding Vm.Status}"      Width="110" SortMemberPath="Vm.Status"/>
                                <DataGridTextColumn Header="Parent PID"  Binding="{Binding Vm.ParentPID}"  Width="95"  SortMemberPath="Vm.ParentPID"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                      Background="{DynamicResource SplitterBrush}"/>

                        <!-- Detail panel -->
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBackground}" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Process Details"
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <ContentControl Content="{Binding SelectedProcess}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource PrimaryForeground}"
                                                           FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="PID"        Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PID}"       Foreground="{DynamicResource PrimaryForeground}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Parent PID" Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ParentPID}" Foreground="{DynamicResource PrimaryForeground}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Status"     Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status}"    Foreground="{DynamicResource PrimaryForeground}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="CPU %"      Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CpuPercent, StringFormat={}{0:F1}%}" Foreground="{DynamicResource PrimaryForeground}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Memory"     Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MemoryMB, StringFormat={}{0} MB}" Foreground="{DynamicResource PrimaryForeground}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Threads"    Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ThreadCount}" Foreground="{DynamicResource PrimaryForeground}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Handles"    Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding HandleCount}" Foreground="{DynamicResource PrimaryForeground}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Started"    Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding StartTimeDisplay}"
                                                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,3" FontSize="11"/>
                                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Path"       Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3"/>
                                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding FullPath}" Foreground="{DynamicResource PrimaryForeground}"
                                                               TextWrapping="Wrap" Margin="0,3" FontSize="11"/>
                                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Command"    Foreground="{DynamicResource SecondaryForeground}" Margin="0,3,12,3" VerticalAlignment="Top"/>
                                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding CommandLine}" Foreground="{DynamicResource MutedForeground}"
                                                               TextWrapping="Wrap" Margin="0,3" FontSize="10"/>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                                <TextBlock Text="No process selected"
                                           Foreground="{DynamicResource MutedForeground}" FontStyle="Italic"
                                           Visibility="{Binding SelectedProcess, TargetNullValue=Visible, FallbackValue=Collapsed}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource SplitterBrush}"/>

                    <!-- Event log -->
                    <Grid Grid.Row="3" Background="{DynamicResource SubSurfaceBackground}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Event Log"
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   FontSize="11" FontWeight="SemiBold" Margin="10,6"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding EventLog}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource SecondaryForeground}"
                                 FontSize="11" FontFamily="Consolas"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss', Mode=OneWay}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource MutedForeground}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSpike}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF5555"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Description, Mode=OneWay}" Margin="8,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSpike}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF5555"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>

                </Grid>
            </TabItem>

            <!-- ── Charts tab ── -->
            <TabItem Header="Charts">
                <views:ChartsView/>
            </TabItem>

        </TabControl>


    </Grid>
</Window>
